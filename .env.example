DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/jobhunt
ANTHROPIC_API_KEY=sk-ant-...

# Discovery APIs
RAPIDAPI_KEY=...
NAUKRI_API_KEY=...
WELLFOUND_API_KEY=...

# Optional enrichment (reuse from trading agent)
TAVILY_API_KEY=...
REDIS_URL=redis://localhost:6379

# Settings (overridden by DB values at runtime)
FIT_SCORE_THRESHOLD=65
MAX_TAILOR_RETRIES=3
DISCOVERY_CRON=0 8 * * *
